import unittest

from task_3 import Value


class TestValue(unittest.TestCase):

    def test_add_and_repr(self):
        x = Value(2.0)
        y = Value(-3.0)
        result = x + y

        self.assertEqual(result.data, -1.0)

        self.assertEqual(repr(result), "Value(data=-1.0)")

    def test_mul(self):
        x = Value(2.0)
        y = Value(-3.0)
        z = Value(10.0)
        result = x * y + z

        self.assertEqual(result.data, 4.0)

        self.assertEqual(repr(result), "Value(data=4.0)")


if __name__ == "__main__":
    unittest.main()
